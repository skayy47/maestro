# ── MAESTRO environment ───────────────────────────────────────────────
# Copy to .env.local and fill in. Never commit .env.local.

# Groq — primary LLM (Llama 3.3 70B). Key: https://console.groq.com/keys
GROQ_API_KEY=

# Gemini — fallback / long-context (optional for MVP)
GEMINI_API_KEY=

# Research agent web search — Tavily (https://tavily.com) or Brave
TAVILY_API_KEY=

# Supabase — run persistence + replay gallery (added in the persistence phase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
